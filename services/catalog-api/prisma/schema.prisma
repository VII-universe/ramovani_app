generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FrameProfile {
  id             String         @id @default(cuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  name           String
  slug           String         @unique
  material       FrameMaterial
  finish         MaterialFinish
  profileWidthMm Float
  totalDepthMm   Float
  rabbetDepthMm  Float
  rabbetWidthMm  Float
  pbr            Json
  pricePerMeter  Float
  currency       String         @default("CZK")
  inStock        Boolean        @default(true)
  thumbnailUrl   String         @default("")
  imageUrls      String[]
  /// Controls visibility in the customer-facing configurator.
  /// Set to false to hide a frame without deleting it (e.g. discontinued).
  isActive       Boolean        @default(true)
  textureUrl     String         @default("")

  @@map("frame_profiles")
}

model PassepartoutProfile {
  id              String            @id @default(cuid())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  name            String
  colorName       String
  colorHex        String
  style           PassepartoutStyle
  thicknessMm     Float
  bevelAngleDeg   Float             @default(45)
  pricePerSqMeter Float
  currency        String            @default("CZK")
  inStock         Boolean           @default(true)
  thumbnailUrl    String

  @@map("passepartout_profiles")
}

model Order {
  id              String      @id @default(uuid())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  status          OrderStatus @default(PENDING)
  customerEmail   String
  totalPrice      Float
  currency        String      @default("CZK")
  configSnapshot  Json
  stripeSessionId String?

  @@map("orders")
}

enum FrameMaterial {
  wood
  metal
  composite
}

enum MaterialFinish {
  matte
  gloss
  satin
  brushed
  natural
  lacquered
}

enum PassepartoutStyle {
  single
  double
  bevel
}

enum OrderStatus {
  PENDING
  PAID
  IN_PRODUCTION
  SHIPPED
  CANCELLED
}
