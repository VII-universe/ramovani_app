VISION_API_HOST=0.0.0.0
VISION_API_PORT=8001
VISION_STATIC_DIR=/tmp/ramovani-static
VISION_MAX_UPLOAD_MB=10
# Minimum contour area (px²) to be considered a valid artwork edge
VISION_MIN_CONTOUR_AREA=5000
# Confidence threshold below which a warning is issued
VISION_CONFIDENCE_WARN_THRESHOLD=0.5
# Confidence threshold below which analysis is rejected
VISION_CONFIDENCE_REJECT_THRESHOLD=0.2
CORS_ORIGINS=http://localhost:3000
